rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened security primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 't4rikulmini@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Strict validation schemas
    function isValidApp(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.shortDescription is string && data.shortDescription.size() <= 500 &&
             data.fullDescription is string && data.fullDescription.size() <= 5000 &&
             data.category is string && data.category.size() <= 100 &&
             data.version is string && data.version.size() <= 50 &&
             data.fileSize is string && data.fileSize.size() <= 50 &&
             data.androidVersion is string && data.androidVersion.size() <= 50 &&
             data.developerName is string && data.developerName.size() <= 200 &&
             data.developerEmail is string && data.developerEmail.size() <= 200 &&
             data.iconUrl is string && data.iconUrl.size() <= 1000 &&
             data.apkUrl is string && data.apkUrl.size() <= 1000 &&
             data.downloads is number &&
             data.featured is bool &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidCategory(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.icon is string && data.icon.size() <= 100;
    }

    // Apps Collection
    match /apps/{appId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(appId) && (request.method == 'create' ? isValidApp(incoming()) : true);
      
      allow update: if isValidId(appId) && (
        (isAdmin() && isValidApp(incoming())) ||
        (
          // Public Action: Single incremental download tracking
          incoming().diff(existing()).affectedKeys().hasOnly(['downloads']) &&
          incoming().downloads is number &&
          incoming().downloads == existing().downloads + 1
        )
      );
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(categoryId) && (request.method in ['create', 'update'] ? isValidCategory(incoming()) : true);
    }

    // Admins Registry Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed exclusively out-of-band for security
    }
  }
}
